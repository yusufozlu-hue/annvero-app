{
  "name": "annvero-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node ./scripts/run-production-build.mjs",
    "start": "next start",
    "lint": "eslint",
    "deploy:onayla": "node .cursor/hooks/deploy-approved.mjs",
    "import:companies": "node scripts/import-companies-json.mjs",
    "test:security": "node --import ./scripts/_alias-loader.mjs ./scripts/test-security-regression.mjs",
    "test:migration-contract": "node --import ./scripts/_alias-loader.mjs ./scripts/test-migration-contract-020-025.mjs",
    "test:security:gates": "node scripts/test-auth-security-gates.mjs && node scripts/test-company-membership-security.mjs && node --import ./scripts/_alias-loader.mjs ./scripts/test-auth-cookie-transport.mjs",
    "security:scan-secrets": "node scripts/security/scan-secrets.mjs",
    "security:scan-client": "node scripts/security/scan-client-secrets.mjs",
    "security:scan-sql": "node scripts/security/scan-destructive-sql.mjs",
    "security:check-routes": "node scripts/security/check-critical-routes.mjs && node scripts/security/check-service-role-routes.mjs",
    "security:ci": "npm run security:scan-secrets && npm run security:scan-client && npm run security:scan-sql && npm run security:check-routes && npm run test:security && npm run test:migration-contract && npm run test:security:gates",
    "test:xlsx-version": "node --import ./scripts/_alias-loader.mjs ./scripts/test-xlsx-version.mjs",
    "backup:dry-run": "node scripts/backup/backup-dry-run.mjs",
    "backup:storage-dry-run": "node scripts/backup/storage-backup-dry-run.mjs",
    "backup:staging-storage": "node scripts/backup/staging-storage-backup.mjs",
    "backup:staging-storage:dry-run": "node scripts/backup/staging-storage-backup.mjs --mode dry-run",
    "backup:immutable-s3:dry-run": "node scripts/backup/staging-storage-backup.mjs --mode dry-run --out .tmp-staging-storage-backup --run-id local-dry-run && node scripts/backup/upload-immutable-s3.mjs --dry-run --out .tmp-staging-storage-backup --github-run-id local-dry-run",
    "lint:security": "eslint src/lib/security src/lib/auth/admin.js src/lib/auth/userAccess.js src/lib/auth/apiGuard.js src/lib/recovery src/lib/backup/companyExport.js src/lib/softDelete.js src/lib/audit app/api/automation/webhook/route.js app/api/backup/company-export/route.js app/api/recovery app/api/tcmb/route.ts app/api/elektraweb/route.ts next.config.ts",
    "test:bank-parser": "node --import ./scripts/_alias-loader.mjs ./scripts/test-bank-parser-stabilization.mjs",
    "test:cari-biletduk": "node --import ./scripts/_alias-loader.mjs ./scripts/test-cari-biletduk-handler-apply.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "xlsx": "file:vendor/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
