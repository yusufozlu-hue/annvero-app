# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# cursor deploy queue (local)
.cursor/deploy-queue.json
.cursor/hooks.log

# local cursor diagnostics / profiling artifacts (keep hooks/rules tracked)
.cursor/diagnostics/
.cursor/analysis-profile*.json
.cursor/deployments-tmp.json
.cursor/test-*-out.txt
.cursor/*-out.txt
*.profile.json
*.diagnostics.json
*.diagnostics.csv
scripts/profile-*.mjs

# local company data exports / backups
annvero-companies-export-*.json
*.backup.json
*.export.json
.tmp-backup-dry-run/
.tmp-staging-storage-backup/
backup-artifacts/
