# ANNVERO ortam değişkenleri — ÖRNEK (gerçek secret yok)
# Kopyala: cp .env.example .env.local
# Production secret'ları Cursor/AI erişebilen dosyalara YAZMAYIN.
# Secret'lar yalnızca Vercel / Railway / GitHub Actions secret store'da tutulur.
# Production ve Preview secret'ları paylaşılmamalı (branch-scoped Preview override).

# --- Uygulama ortamı ---
# development | test | staging | production
ANNVERO_APP_ENV=development

# Yerel geliştirmede bilinen production/staging Supabase ref'ine izin vermek için (varsayılan kapalı)
# ANNVERO_ALLOW_REMOTE_SUPABASE=1

# --- Public (tarayıcıya gidebilir) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-local-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_local_anon_key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Server-only (ASLA NEXT_PUBLIC_ öneki kullanma) ---
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_local_service_role_key

# GİB credential encryption — exact ad (çoğul). Tekil GIB_CREDENTIAL_ENCRYPTION_KEY kullanılmaz.
GIB_CREDENTIALS_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# GOOGLE_DRIVE_TOKEN_ENCRYPTION_KEY=base64-32-byte-key
# ANNVERO_FIELD_ENCRYPTION_KEY=base64-32-byte-key

# Admin allowlist (tercihen server-only; NEXT_PUBLIC_ kullanmayın)
ANNVERO_ADMIN_EMAILS=you@example.com
ANNVERO_OWNER_EMAILS=you@example.com

# GİB otomasyon (Railway) — staging yoksa tanımlamayın (fail-closed / not configured)
# GIB_AUTOMATION_SERVICE_URL=https://your-gib-service.example
# GIB_AUTOMATION_SERVICE_TOKEN=your_token

# Webhook — staging/preview/production: HMAC zorunlu (secret yoksa fail-closed)
# N8N_AUTOMATION_WEBHOOK_HMAC_SECRET=your_hmac_secret_placeholder
# Legacy Bearer yalnız local development/test:
# N8N_AUTOMATION_WEBHOOK_SECRET=your_webhook_bearer_secret_placeholder

# Rate limit — staging/preview/production: durable zorunlu
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token
ANNVERO_RATE_LIMIT_BACKEND=supabase

# Recovery — production/staging/preview: yalnız true ile açık; missing/false → kapalı
# Local development/test: varsayılan açık; kapatmak için false
# RECOVERY_API_ENABLED=true

# CORS / CSRF allowlist (virgülle) — Preview URL sonrası güncellenir
# ANNVERO_ALLOWED_ORIGINS=https://app.example.com

# Bilinen remote project ref'ler (bilgi amaçlı — bağlanma):
# production: ttxigznwcjvrlzuppbro
# staging:    bveipjvbopbkvojfdpmo
